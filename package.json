{
  "name": "ecell-startup-portal",
  "version": "1.1.0",
  "main": "index.js",
  "keywords": [
    "react",
    "reactjs",
    "ecell",
    "startup",
    "startup-portal"
  ],
  "author": "E-cell",
  "license": "MIT",
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "install:clean": "rm -rf node_modules/ && rm -rf package-lock.json && npm install && npm start",
    "compile-sass": "node-sass src/assets/scss/argon-dashboard-react.scss src/assets/css/argon-dashboard-react.css",
    "minify-sass": "node-sass src/assets/scss/argon-dashboard-react.scss src/assets/css/argon-dashboard-react.min.css --output-style compressed",
    "map-sass": "node-sass src/assets/scss/argon-dashboard-react.scss src/assets/css/argon-dashboard-react.css --source-map true"
  },
  "eslintConfig": {
    "extends": "react-app"
  },
  "browserslist": [
    ">0.2%",
    "not dead",
    "not ie <= 11",
    "not op_mini all"
  ],
  "dependencies": {
    "@fortawesome/fontawesome-free": "5.12.1",
    "ag-grid-community": "^24.1.0",
    "ag-grid-react": "^24.1.1",
    "axios": "^0.21.0",
    "classnames": "2.2.6",
    "jsonwebtoken": "^8.5.1",
    "jwt-decode": "^3.0.0",
    "moment": "2.24.0",
    "node-sass": "4.14.1",
    "nouislider": "14.1.1",
    "react": "16.12.0",
    "react-cookie": "^4.0.3",
    "react-copy-to-clipboard": "5.0.2",
    "react-datetime": "2.16.3",
    "react-dom": "16.12.0",
    "react-dropzone-uploader": "^2.11.0",
    "react-google-maps": "^9.4.5",
    "react-password-strength-bar": "^0.3.2",
    "react-redux": "^7.2.2",
    "react-router-dom": "5.1.2",
    "react-scripts": "^3.4.4",
    "reactstrap": "8.4.1",
    "redux": "^4.0.5",
    "redux-thunk": "^2.3.0",
    "sfcookies": "^1.0.2"
  },
  "devDependencies": {
    "@types/googlemaps": "3.39.2",
    "@types/markerclustererplus": "2.1.33",
    "@types/react": "16.9.19",
    "eslint-plugin-flowtype": "3.13.0",
    "gulp": "^4.0.2",
    "gulp-append-prepend": "1.0.8",
    "typescript": "3.7.5"
  }
}
